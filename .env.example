# LinkedIn Prospecting Agents - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# CLAUDE API (Required for AI analysis)
# ============================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# LINKEDIN API (Required for profile data)
# ============================================
# Use a provider like:
# - Proxycurl: https://nubela.co/proxycurl/
# - Rainmaker: https://rainmaker.hypefactors.com/
# - LinkedIn Sales Navigator API (enterprise)
LINKEDIN_API_KEY=your_api_key_here

# ============================================
# NOTION API (Required for lead database)
# ============================================
# Get from: https://www.notion.so/my-integrations
# Create an integration, then share your database with it
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=your_database_id_here

# ============================================
# OPTIONAL: Webhook for notifications
# ============================================
# Send pipeline completion notifications to this URL
# WEBHOOK_URL=https://your-webhook.com/notify

# ============================================
# OPTIONAL: Proxy settings (for LinkedIn scraping)
# ============================================
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080
